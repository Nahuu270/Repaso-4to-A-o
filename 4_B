#include <iostream>
using namespace std;

int main(){
    int numero;
    
    cout << "Cantidad de elementos: " << endl;
    cin >> numero;
    
    int arr[numero];
    
    for (int i = 0; i < numero; i++){
        cout << "Elemento " << i + 1 << ": " << endl;
        cin >> arr[i];
    }
    
    int maximo = arr[0];
    
    for (int i = 1; i < numero; i++){
        if (arr[i] > maximo){
            maximo = arr[i];
        }
    }
    
    cout << "El maximo es: " << maximo << endl;
    return 0;
}
