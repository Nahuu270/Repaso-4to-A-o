#include <iostream>
using namespace std;

int main(){
    int dia;
    
    cout << "Ingrese un numero del 1 al 7:" << endl;
    cin >> dia;
    
    if(dia == 1) cout << "Lunes" << endl;
    else if (dia == 2) cout << "Martes" << endl;
    else if (dia == 3) cout << "Miercoles" << endl;
    else if (dia == 4) cout << "Jueves" << endl;
    else if (dia == 5) cout << "Viernes" << endl;
    else if (dia == 6) cout << "Sabado" << endl;
    else if (dia == 7) cout << "Domingo" << endl;
    else cout << "Error: ingrese numero de 1 al 7";
    return 0;
}
