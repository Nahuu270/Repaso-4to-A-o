#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main(){
    srand(time(0));
    
    int corredor1 = 0;
    int corredor2 = 0;
    int meta = 100;
    int segundos = 0;
    
    while(corredor1 < meta && corredor2 < meta){
        corredor1 += rand() % 10 + 1;
        corredor2 += rand() % 10 + 1;
        segundos++;
    }
    
    if (corredor1 >= meta && corredor2 >= meta){
        cout << "Empate en " << segundos << " segundos" << endl;
    } else if (corredor1 >= meta){
        cout << "Gano el corredor 1 en " << segundos << " segundos" << endl;
    } else {
        cout << "Gano el corredor 2 en " << segundos << " segundos" << endl;
    }
    
    return 0;
}
