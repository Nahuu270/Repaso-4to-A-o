#include <iostream>
using namespace std;

int main() {
    int numero;
    cout << "Cantidad de elementos: " << endl;
    cin >> numero;

    int arr[numero];
    int suma = 0;

    for (int i = 0; i < numero; i++) {
        cout << "Elemento " << i+1 << ": ";
        cin >> arr[i];
        suma += arr[i];
    }

    cout << "La suma es: " << suma << endl;;
    return 0;
}
