#include <iostream>
using namespace std;

int main(){
    int numero;
    
    cout << "Cantidad de elementos" << endl;
    cin >> numero;
    
    int arr[numero];
    int pares = 0;
    
    for(int i = 0; i < numero; i++){
        cout << "Elemento " << i + 1 << ": " << endl;
        cin >> arr[i];
        
        if (arr[i] % 2 == 0){
            pares++;
        }
    }
    
    cout << "La cantidad de pares es: " << pares << endl;
    return 0;
}
